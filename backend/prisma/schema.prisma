// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SeatStatus {
  Available
  Booked
  Unavailable
}

enum TicketStatus {
  Open
  Canceled
  Resolved
}

enum OrderStatus {
  Pending
  Confirmed
  Denied
}

model Customer {
  customerId String     @id
  fullname   String      
  email      String     @unique
  phone      String
  password   String
  rank       Int
  point      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt @default(now())
  orders     Order[]
  feedbacks  Feedback[]
}

model Shift {
  shiftId   Int      @id @default(autoincrement())
  staffId   String
  startTime DateTime @db.Time()
  endTime   DateTime @db.Time()
  staff     Staff    @relation(fields: [staffId], references: [staffId], onDelete: Cascade)
}

model Staff {
  staffId   String   @id
  fullname  String
  email     String   @unique
  phone     String
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  orders    Order[]
  shifts    Shift[]
}

model Payment {
  paymentId Int      @id @default(autoincrement())
  orderId   Int
  methodId  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  method    Method   @relation(fields: [methodId], references: [methodId])
  order     Order?
}

model Method {
  methodId    Int       @id @default(autoincrement())
  name        String
  description String
  Payments    Payment[]
}

model Order {
  orderId    Int         @id @default(autoincrement())
  customerId String
  staffId    String?
  status     OrderStatus
  paymentId  Int?        @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt @default(now())
  customer   Customer    @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  staff      Staff?      @relation(fields: [staffId], references: [staffId])
  payment    Payment?    @relation(fields: [paymentId], references: [paymentId])
  tickets    Ticket[]
}

model Ticket {
  ticketId  Int          @id @default(autoincrement())
  orderId   Int
  passCCCD  String
  passName  String
  status    TicketStatus @default(Open)
  seatId    Int?          @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt @default(now())
  order     Order        @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  seat      Seat?        @relation(fields: [seatId], references: [seatId])
}

model Seat {
  seatId      Int        @id @default(autoincrement())
  status      SeatStatus @default(Available)
  tripId      Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt @default(now())
  seatClassId Int         
  seatClass   SeatClass  @relation(fields: [seatClassId], references: [seatClassId])
  ticket      Ticket?
  trip        Trip       @relation(fields: [tripId], references: [tripId], onDelete: Cascade)
}

model Trip {
  tripId      Int      @id @default(autoincrement())
  track       String
  arrivalDate DateTime 
  stationId   String?
  seats       Seat[]
  station     Station?  @relation(fields: [stationId], references: [stationId])
}

model SeatClass {
  seatClassId    Int    @id @default(autoincrement())
  name           String
  price          Float
  seats          Seat[]
}

model Feedback {
  feedbackId Int      @id @default(autoincrement())
  customerId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())
  customer   Customer @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
}

model Station {
  stationId     String    @id
  name          String
  location      String
  trips         Trip[]
}
model StationConnection{
  stationConnectionId  Int     @id @default(autoincrement())
  startStationId       String
  endStationId         String
  
}
model Route{
  routeId     Int     @id @default(autoincrement())
  tripId      Int
  travelTime  Int    //in minutes
}
